function getInsGroups(entries){
  const map={};const order=[];
  entries.forEach(e=>{
    if(!map[e.instructor.id]){map[e.instructor.id]={ins:e.instructor,entries:[]};order.push(e.instructor.id);}
    map[e.instructor.id].entries.push(e);
  });
  return order.map(id=>map[id]);
}

