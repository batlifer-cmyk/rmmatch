    const bi=SLOT_CATEGORY_INFO[b.category]||SLOT_CATEGORY_INFO.manual_review;
    if(ai.order!==bi.order)return ai.order-bi.order;
    return (b.score||0)-(a.score||0);
  });

  const grouped={};
  slots.forEach(s=>{if(!grouped[s.category])grouped[s.category]=[];grouped[s.category].push(s);});
  Object.keys(grouped).sort((a,b)=>(SLOT_CATEGORY_INFO[a]?.order||99)-(SLOT_CATEGORY_INFO[b]?.order||99)).forEach((cat,catIdx)=>{
    const info=SLOT_CATEGORY_INFO[cat]||SLOT_CATEGORY_INFO.manual_review;
