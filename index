// ── INIT
function loadData(){
  const s=localStorage.getItem('rm_instructors');
  instructors=s?JSON.parse(s):JSON.parse(JSON.stringify(DEFAULTS));
  refreshInsSel();
}
function saveData(){localStorage.setItem('rm_instructors',JSON.stringify(instructors));}
function refreshInsSel(){
  const el=document.getElementById('s-instructor-direct');
  el.innerHTML='';
  instructors.forEach(ins=>{
    const lbl=document.createElement('label');
    lbl.className='check-item';
    const inp=document.createElement('input');
    inp.type='checkbox'; inp.value=ins.id;
    inp.style.display='none';
    lbl.onclick=()=>{inp.checked=!inp.checked;lbl.classList.toggle('checked',inp.checked);};
    lbl.appendChild(inp); lbl.appendChild(document.createTextNode(ins.name));
    el.appendChild(lbl);
  });
}

