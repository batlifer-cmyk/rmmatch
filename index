function getAvailabilityWarnings(){
  const directIds=getDirectInstructorIds();
  const dayTimeMap=getDayTimeMap();
  const requestedDays=Object.keys(dayTimeMap);
  if(!directIds.length||!requestedDays.length)return [];
  const warnings=[];
  directIds.forEach(id=>{
    const ins=instructors.find(i=>i.id===id);
    if(!ins)return;
    const impossible=[];
    requestedDays.forEach(day=>{
      const times=dayTimeMap[day]||[];
      times.forEach(t=>{
        if(!ins.days.includes(day)||!ins.times.includes(t))impossible.push(day+'요일 '+t);
      });
    });
    if(impossible.length){
      warnings.push(ins.name+' 강사 설정상 '+impossible.join(', ')+'이 가능시간에 없습니다. 이 시간을 추천하려면 강사 설정 탭에서 해당 요일/시간을 추가해야 합니다.');
    }
  });
  return warnings;
}
