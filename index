// 학생 희망조건과의 근접도 계산
// 같은 카테고리 안에서 “진짜 좋은 근접안”이 위로 오도록 쓰는 보조 점수다.
function timeToMinutes(t){
  if(!t||typeof t!=='string')return null;
  const m=t.match(/^(\d{1,2}):(\d{2})$/);
  if(!m)return null;
  return parseInt(m[1],10)*60+parseInt(m[2],10);
}
function circularDayDistance(a,b){
  const ia=DAYS.indexOf(a), ib=DAYS.indexOf(b);
  if(ia<0||ib<0)return 9;
  const diff=Math.abs(ia-ib);
  return Math.min(diff,7-diff);
}
function getRequestedTimesFlat(dayTimeMap){
  const out=[];
  Object.keys(dayTimeMap||{}).forEach(d=>{
    (dayTimeMap[d]||[]).forEach(t=>out.push({day:d,time:t,minutes:timeToMinutes(t)}));
  });
  return out;
}
function getSlotRequestFit(slot,dayTimeMap){
  const requestedDays=Object.keys(dayTimeMap||{});
  const requestedTimesFlat=getRequestedTimesFlat(dayTimeMap);
  if(!requestedDays.length){
    return {score:0, exact:true, sameDay:true, maxTimeDiff:0, sameDayCount:0, reason:'학생 희망 요일 미지정'};
  }
  let score=0;
  let exactCount=0, sameDayCount=0, oneHourCount=0, twoHourCount=0, farCount=0, dayShiftPenalty=0;
  let maxTimeDiff=0;
  slot.entries.forEach(e=>{
    const wantedTimes=dayTimeMap[e.day]||[];
    const eMin=timeToMinutes(e.time);
    if(requestedDays.includes(e.day)){
      sameDayCount++;
      score+=14; // 같은 요일 유지
      if(!wantedTimes.length){
        score+=10; // 요일만 지정한 경우: 그 요일이면 좋은 후보
        return;
      }
      const diffs=wantedTimes.map(t=>Math.abs((timeToMinutes(t)??eMin)-eMin));
      const minDiff=Math.min(...diffs);
      maxTimeDiff=Math.max(maxTimeDiff,minDiff);
      if(minDiff===0){exactCount++;score+=24;}
      else if(minDiff<=60){oneHourCount++;score+=16;}
      else if(minDiff<=120){twoHourCount++;score+=8;}
      else {farCount++;score-=Math.min(12,Math.floor(minDiff/60)*3);}
    } else {
      // 요청 요일과 다르면 가장 가까운 요청요일까지의 거리만큼 감점
      const dd=Math.min(...requestedDays.map(d=>circularDayDistance(e.day,d)));
      dayShiftPenalty+=dd;
      score-=12+dd*4;
      // 그래도 요청 시간대와 가까우면 약간 보정
      if(requestedTimesFlat.length&&eMin!==null){
        const minT=Math.min(...requestedTimesFlat.map(x=>Math.abs((x.minutes??eMin)-eMin)));
        maxTimeDiff=Math.max(maxTimeDiff,minT);
        if(minT===0)score+=6;
        else if(minT<=60)score+=3;
      }
    }
  });
  const allSameTime=new Set(slot.entries.map(e=>e.time)).size===1;
  if(allSameTime)score+=8; // 요일별 같은 시간 배치 우선
  const exact=exactCount===slot.entries.length;
  const sameDay=sameDayCount===slot.entries.length;
  let reason='';
  if(exact) reason='희망 요일·시간 완전 일치';
  else if(sameDay && oneHourCount>0 && farCount===0) reason='같은 요일, 희망시간 ±1시간 중심';
  else if(sameDay) reason='같은 요일 유지, 시간 조정';
  else if(dayShiftPenalty<=slot.entries.length) reason='요일 일부 조정, 시간대 근접';
  else reason='요일·시간 조정폭 큼';
  return {score, exact, sameDay, maxTimeDiff, sameDayCount, oneHourCount, twoHourCount, farCount, reason};
}
function getConnectionFit(slot){
  // 기존 수업 전후 배치와 연강 한도를 세밀하게 점수화한다.
  let score=0;
  let adjacentCount=0, sameDayBusyCount=0, maxRunExceeded=false;
  slot.entries.forEach(entry=>{
    const ins=entry.instructor;
    const cache=ins&&icsCache[ins.id];
    if(!cache||!cache.slots||!cache.slots.length)return;
    const dow=DAY_KO.indexOf(entry.day);
    const h=parseInt(entry.time.split(':')[0],10);
    const sameDay=cache.slots.filter(s=>s.dow===dow);
    if(!sameDay.length){score-=2;return;}
    sameDayBusyCount++;
    score+=7; // 기존 수업 있는 요일에 배치
    const minGap=sameDay.reduce((min,s)=>Math.min(min,Math.abs(s.hour-h)),999);
    if(minGap===1){adjacentCount++;score+=9;}      // 바로 앞뒤 연강
    else if(minGap===2){score+=2;}                // 1시간 공백 후 배치
    else if(minGap>=3){score-=4;}                 // 동선상 덜 효율적
    const maxC=ins.maxConsec||4;
    const hours=[...sameDay.map(s=>s.hour),h].sort((a,b)=>a-b);
    let maxRun=1,run=1;
    for(let i=1;i<hours.length;i++){
      if(hours[i]-hours[i-1]===1){run++;maxRun=Math.max(maxRun,run);} else run=1;
    }
    if(maxRun>maxC){maxRunExceeded=true;score-=200;}
  });
  return {score, adjacentCount, sameDayBusyCount, maxRunExceeded};
}
function getInstructorPreferenceFit(slot,directIds){
  if(!directIds||!directIds.length)return {score:0, allPreferred:false, anyPreferred:false};
  const allPreferred=slot.entries.every(e=>e.instructor&&directIds.includes(e.instructor.id));
  const anyPreferred=slot.entries.some(e=>e.instructor&&directIds.includes(e.instructor.id));
  let score=0;
  if(allPreferred)score+=120;
  else if(anyPreferred)score+=55;
  return {score, allPreferred, anyPreferred};
}

// ── SCHEDULING
// slot item: { entries:[{instructor,day,time}], multiInstructor:bool, score, label }

function computeSlots(){
  const dayTimeMap=getDayTimeMap();
  const studentDays=Object.keys(dayTimeMap);
  const subjects=getChecked('s-subjects');
  const freq=parseInt(document.getElementById('s-freq').value);
  const directIds=Array.from(document.querySelectorAll('#s-instructor-direct input:checked')).map(i=>i.value);

  let cands=[...instructors];
  if(subjects.length>0) cands=cands.filter(ins=>subjects.some(s=>ins.subjects.includes(s)));

  let results=[];

  // ── 1. Single-instructor options
  cands.forEach(ins=>{
    const availDays=ins.days;
    if(availDays.length<freq)return;
    getCombos(availDays,freq).forEach(combo=>{
      const dayOptions=combo.map(day=>{
        // 학생이 특정 시간을 요청했더라도, 그 시간이 안 되면 같은 요일의 다른 시간도 대안으로 보여줘야 한다.
        // 정확히 일치하는 시간은 아래 scoring/classification 단계에서 우선권을 받는다.
        const cand=ins.times;
        return{day,cand};
      });
      if(dayOptions.some(o=>o.cand.length===0))return;
      buildSingleInsSchedules(ins,dayOptions,0,[],results);
    });
  });

  // ── 2. Multi-instructor options
  if(freq>=2 && cands.length>=2){
    // Use all instructor days when student has no day preference
    const allCandDays=[...new Set(cands.flatMap(i=>i.days))];
    const targetDays=allCandDays;

    // Build per-day candidate slots: day -> [{instructor, day, time}]
    const daySlots={};
    targetDays.forEach(day=>{
      daySlots[day]=[];
      cands.forEach(ins=>{
        if(!ins.days.includes(day))return;
        // 2인 병행 후보도 학생 요청시간에만 고정하지 않고 같은 요일 내 시간 조정안을 허용한다.
        const times=ins.times;
        times.forEach(t=>{
          if(!isConflict(ins.id,day,t)) daySlots[day].push({instructor:ins,day,time:t});
        });
      });
    });

    const daysWithSlots=targetDays.filter(d=>daySlots[d]&&daySlots[d].length>0);
    if(daysWithSlots.length>=freq){
      getCombos(daysWithSlots,freq).forEach(combo=>{
        // Extract combo's daySlots for closure safety
        const comboSlots=combo.map(d=>daySlots[d]);
        const buildMulti=(idx,current)=>{
          if(idx===combo.length){
            const insIds=new Set(current.map(e=>e.instructor.id));
            if(insIds.size<2)return; // single-ins already covered above
            results.push({entries:[...current],multiInstructor:true});
            return;
          }
          comboSlots[idx].forEach(slot=>buildMulti(idx+1,[...current,slot]));
        };
        buildMulti(0,[]);
      });
    }
  }

  // ── Deduplicate
  const seen=new Set();
  results=results.filter(r=>{
    const k=r.entries.map(e=>e.instructor.id+e.day+e.time).sort().join('|');
    if(seen.has(k))return false; seen.add(k); return true;
  });

  // ── Score (선택강사 우선 + 희망조건 근접도 + 연강 최적화)
  results.forEach(r=>{
    const allSameTime=new Set(r.entries.map(e=>e.time)).size===1;
    const allSameIns=new Set(r.entries.map(e=>e.instructor.id)).size===1;
    let score=0;
    if(allSameIns) score+=12;
    if(allSameTime) score+=8; // 요일별 같은 시간으로 수업 배치 우선

    const prefFit=getInstructorPreferenceFit(r,directIds);
    const reqFit=getSlotRequestFit(r,dayTimeMap);
    const connFit=getConnectionFit(r);
    score+=prefFit.score;
    score+=reqFit.score;
    score+=connFit.score;

    r.fit={preferred:prefFit,requested:reqFit,connection:connFit};

    if(allSameIns){
      r.insLabel=r.entries[0].instructor.name;
    } else {
      const parts=r.entries.map(e=>`${e.day}: ${e.instructor.name.split(' ')[0]}`);
      r.insLabel=parts.join(' / ');
    }

    r.score=score;
    r.label=r.entries.map(e=>`${e.day}요일 ${fmtTime(e.time)}`).join(' / ');
  });

  // maxConsec 초과 제거
  results=results.filter(r=>!(r.fit&&r.fit.connection&&r.fit.connection.maxRunExceeded));

  // Split and cap separately so multi-instructor results always appear
  const single=results.filter(r=>!r.multiInstructor).sort((a,b)=>b.score-a.score).slice(0,20);
  const multi=results.filter(r=>r.multiInstructor).sort((a,b)=>b.score-a.score).slice(0,10);
  return [...single,...multi];
}

function buildSingleInsSchedules(ins,dayOptions,idx,current,out){
  if(idx===dayOptions.length){
    out.push({entries:current.map(s=>({instructor:ins,day:s.day,time:s.time})),multiInstructor:false});
    return;
  }
  dayOptions[idx].cand.forEach(t=>{
    if(!isConflict(ins.id,dayOptions[idx].day,t))
      buildSingleInsSchedules(ins,dayOptions,idx+1,[...current,{day:dayOptions[idx].day,time:t}],out);
  });
}

function getCombos(arr,k){
  if(k===1)return arr.map(x=>[x]);
  const res=[];
  for(let i=0;i<=arr.length-k;i++)
    getCombos(arr.slice(i+1),k-1).forEach(r=>res.push([arr[i],...r]));
  return res;
}
function isConflict(insId,day,time){return isConflictICS(insId,day,time);}

