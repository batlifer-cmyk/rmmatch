function slotMatchesRequestedDaysAndTimes(slot){
  const dayTimeMap=getDayTimeMap();
  const requestedDays=Object.keys(dayTimeMap);
  if(!requestedDays.length)return true;
  return slot.entries.every(e=>{
    if(!requestedDays.includes(e.day))return false;
    const requestedTimes=dayTimeMap[e.day]||[];
    return requestedTimes.length===0 || requestedTimes.includes(e.time);
  });
}
function slotMatchesRequestedDays(slot){
  const dayTimeMap=getDayTimeMap();
  const requestedDays=Object.keys(dayTimeMap);
  if(!requestedDays.length)return true;
  return slot.entries.every(e=>requestedDays.includes(e.day));
}
function slotUsesOnlyPreferredInstructor(slot){
  const ids=getDirectInstructorIds();
  if(!ids.length)return false;
  return !slot.multiInstructor && slot.entries.every(e=>e.instructor&&ids.includes(e.instructor.id));
}
function slotUsesAnyPreferredInstructor(slot){
  const ids=getDirectInstructorIds();
  if(!ids.length)return false;
  return slot.entries.some(e=>e.instructor&&ids.includes(e.instructor.id));
}
function classifySlot(slot){
  const ids=getDirectInstructorIds();
  const exact=slotMatchesRequestedDaysAndTimes(slot);
  const sameDay=slotMatchesRequestedDays(slot);
  const preferredOnly=slotUsesOnlyPreferredInstructor(slot);
  const anyPreferred=slotUsesAnyPreferredInstructor(slot);
  const single=!slot.multiInstructor && new Set(slot.entries.map(e=>e.instructor.id)).size===1;

  if(ids.length){
    if(preferredOnly && exact)return 'preferred_exact';
    if(preferredOnly && sameDay)return 'preferred_same_day_adjust_time';
    if(preferredOnly)return 'preferred_other_day';
    if(single && exact)return 'alternative_single_exact';
    if(single)return 'alternative_single_near';
    if(slot.multiInstructor && anyPreferred)return 'multi_with_preferred';
    if(slot.multiInstructor)return 'multi_instructor';
    return 'manual_review';
  }
  if(single && exact)return 'single_exact';
  if(single)return 'single_near';
  if(slot.multiInstructor)return 'multi_instructor';
  return 'manual_review';
}
