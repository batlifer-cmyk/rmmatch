function parseClaudeJSON(text){
  const cleaned=String(text||'').replace(/```json|```/g,'').trim();
  try{return JSON.parse(cleaned);}catch(_){/* fall through */}
  const start=cleaned.indexOf('{');
  if(start<0)throw new Error('Claude 응답에서 JSON을 찾지 못했습니다.');
  let depth=0,inString=false,esc=false;
  for(let i=start;i<cleaned.length;i++){
    const ch=cleaned[i];
    if(esc){esc=false;continue;}
    if(ch==='\\'){esc=true;continue;}
    if(ch==='"'){inString=!inString;continue;}
    if(inString)continue;
    if(ch==='{')depth++;
    if(ch==='}'){
      depth--;
      if(depth===0){
        return JSON.parse(cleaned.slice(start,i+1));
      }
    }
  }
  throw new Error('JSON 괄호가 닫히지 않았습니다.');
}

function matchInstructorByName(name){
  const raw=String(name||'').toLowerCase().replace(/[^a-z가-힣]/g,'');
  if(!raw)return null;
  return instructors.find(i=>{
    const full=i.name.toLowerCase().replace(/[^a-z가-힣]/g,'');
    const parts=i.name.toLowerCase().split(/\s+/).filter(Boolean);
    return raw.includes(full)||full.includes(raw)||parts.some(p=>raw.includes(p.replace(/[^a-z가-힣]/g,'')));
  })||null;
}

function buildAISuggestionsFromFreeGroups(freeGroups){
  const dayTimeMap=getDayTimeMap();
  const studentDays=Object.keys(dayTimeMap);
  const freq=lessonType==='flex'?1:parseInt(document.getElementById('s-freq').value||'1');
  const directIds=Array.from(document.querySelectorAll('#s-instructor-direct input:checked')).map(i=>i.value);
  const out=[];

  freeGroups.forEach(group=>{
    const ins=group.instructor||matchInstructorByName(group.name)||(directIds.length?instructors.find(i=>i.id===directIds[0]):instructors[0]);
    if(!ins)return;
    let slots=(group.slots||[]).filter(s=>DAYS.includes(s.day)&&/^\d{2}:\d{2}$/.test(s.time));
    if(studentDays.length>0){
      // AI가 판독한 free 후보는 요청 요일을 우선하되, 같은 요일의 다른 시간도 시간 조정안으로 남긴다.
      slots=slots.filter(s=>studentDays.includes(s.day));
    }
    slots=slots.filter(s=>!isConflict(ins.id,s.day,s.time));
    const byDay={};
    slots.forEach(s=>{if(!byDay[s.day])byDay[s.day]=[];byDay[s.day].push(s);});
    const days=Object.keys(byDay);
    if(days.length<freq)return;

    getCombos(days,freq).slice(0,8).forEach(combo=>{
      const choices=combo.map(d=>byDay[d].slice(0,4));
      const build=(idx,current)=>{
        if(out.length>=16)return;
        if(idx===choices.length){
          const entries=current.map(s=>({instructor:ins,day:s.day,time:s.time}));
          out.push({
            entries,
            multiInstructor:false,
            score:40,
            source:'ai',
            aiSuggested:true,
            label:entries.map(e=>`${e.day}요일 ${fmtTime(e.time)}`).join(' / ')
          });
          return;
        }
        choices[idx].forEach(s=>build(idx+1,[...current,s]));
      };
      build(0,[]);
    });
  });

  const seen=new Set();
  return out.filter(slot=>{
    const key=slot.entries.map(e=>e.instructor.id+e.day+e.time).join('|');
    if(seen.has(key))return false;
    seen.add(key);return true;
  }).slice(0,12);
}

