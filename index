    const summary=document.createElement('summary');
    summary.innerHTML=`<span class="group-title"><span>${info.icon}</span><span>${info.title}</span><span class="count">${group.length}개</span></span><span class="chev">⌄</span>`;
    const body=document.createElement('div');
    body.className='slot-group-body';
    if(info.desc){
      const desc=document.createElement('div');
      desc.className='slot-category-desc';
      desc.textContent=info.desc;
      body.appendChild(desc);
    }
    group.forEach(slot=>body.appendChild(renderSlotCard(slot,subjects,freq)));
    details.appendChild(summary);
    details.appendChild(body);
