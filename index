function renderAISlots(slots,instructorGroups){
  const el=document.getElementById('aiSlotList');
  const wrap=document.getElementById('aiAnalysisResult');
  wrap.style.display='block';
  el.innerHTML='';

  // instructorGroups: [{name, slots}] from new format
  // slots: fallback from old format
  let groups=instructorGroups||[{name:'전체',slots:slots||[]}];
  const preferredIds=getDirectInstructorIds();
  groups=[...groups].sort((a,b)=>{
    const ai=a.instructor||matchInstructorByName(a.name);
    const bi=b.instructor||matchInstructorByName(b.name);
    const ap=ai&&preferredIds.includes(ai.id)?0:1;
    const bp=bi&&preferredIds.includes(bi.id)?0:1;
    return ap-bp;
  });
  let totalCount=0;

  groups.forEach(group=>{
    if(!group.slots||!group.slots.length)return;
    totalCount+=group.slots.length;

    // 강사 헤더
    const insHdr=document.createElement('div');
    insHdr.style.cssText='font-size:12px;font-weight:700;color:var(--border);margin:12px 0 6px;padding:4px 8px;background:var(--surface);border-radius:3px;display:inline-block';
    insHdr.textContent='👤 '+group.name;
    el.appendChild(insHdr);

    // 날짜별 그룹
    const byDate={};
    group.slots.forEach(s=>{
      const key=s.date||'날짜 미확인';
      if(!byDate[key])byDate[key]=[];
      byDate[key].push(s);
    });

    Object.entries(byDate).forEach(([dateKey,dateSlots])=>{
      if(dateKey!=='날짜 미확인'){
        const hdr=document.createElement('div');
        hdr.style.cssText='font-size:11px;font-weight:600;color:var(--muted);margin:6px 0 3px;padding-left:2px';
        hdr.textContent=fmtDate(dateKey)+' ('+dateSlots[0].day+'요일)';
        el.appendChild(hdr);
      }
      dateSlots.forEach(s=>{
        const div=document.createElement('div');
        div.className='ai-result-slot';
        const dateLabel=s.date?fmtDate(s.date)+' ':'';
        const insName=group.name!=='전체'?group.name:null;
        div.innerHTML='<span>🔎</span><span><b>'+dateLabel+s.day+'요일 '+fmtTime(s.time)+'</b>'+(insName?'<span style="font-size:11px;color:inherit;opacity:.7;margin-left:6px">'+insName+'</span>':'')+'</span><span style="font-size:11px;color:inherit;opacity:.6;margin-left:auto">검토용</span>';
        div.onclick=()=>{
          div.classList.toggle('picked');
          // injectAISlot에 강사 이름도 전달
          injectAISlot({...s,instructorName:insName},div.classList.contains('picked'));
        };
        el.appendChild(div);
      });
    });
  });

  document.getElementById('aiUploadLabel').textContent='✅ '+totalCount+'개 빈 후보 원자료 감지됨 — 실제 추천은 아래 추천 일정에서 확인';
}
function injectAISlot(s,add){
  const directIds=Array.from(document.querySelectorAll('#s-instructor-direct input:checked')).map(i=>i.value);
  // 강사 이름으로 매칭 시도
  let ins=null;
  if(s.instructorName&&s.instructorName!=='전체'){
    ins=instructors.find(i=>i.name.includes(s.instructorName.split(' ')[0])||s.instructorName.includes(i.name.split(' ')[0]));
  }
  if(!ins)ins=directIds.length>0?instructors.find(i=>i.id===directIds[0]):instructors[0];
  if(!ins)return;
  const synSlot={entries:[{instructor:ins,day:s.day,time:s.time}],multiInstructor:false,score:15,label:s.day+'요일 '+fmtTime(s.time)+' (AI)',aiSuggested:true};
  const container=document.getElementById('slotResults');
  const eid='ai-'+s.day+'-'+s.time.replace(':','-');
  if(add){
    if(container.querySelector('#'+eid))return;
    const div=document.createElement('div');div.className='slot-result';div.id=eid;
    const freq=lessonType==='flex'?'비고정':document.getElementById('s-freq').value+'회';
    synSlot.source='ai';
    div.innerHTML='<div style="flex:1"><div class="si">🤖 '+synSlot.label+'</div><div class="sm" style="display:flex;align-items:center;gap:8px;margin-top:5px"><span style="background:#e8f5e9;color:#2e7d32;padding:2px 8px;border-radius:10px;font-size:11px">AI 추천</span><span style="font-size:11px;color:var(--muted)">'+freq+'</span></div></div><div style="font-size:12px;opacity:.5;margin-left:12px">선택 →</div>';
    div.onclick=()=>{document.querySelectorAll('.slot-result').forEach(r=>r.classList.remove('chosen'));div.classList.add('chosen');selectedSlot=synSlot;};
    container.insertBefore(div,container.firstChild);div.click();
  } else {
    const el=container.querySelector('#'+eid);if(el)el.remove();
  }
}
