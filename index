function fmtTime(t){
  if(!t)return'';
  const [h,m]=t.split(':').map(Number);
  const ap=h<12?'오전':'오후';
  const h12=h===0?12:h>12?h-12:h;
  return `${ap} ${h12}시${m>0?' '+m+'분':''}`;
}
function fmtDate(s){
  if(!s)return'';
  const d=new Date(s+'T00:00:00');
  const days=['일','월','화','수','목','금','토'];
  return `${d.getMonth()+1}월 ${d.getDate()}일(${days[d.getDay()]})`;
}

