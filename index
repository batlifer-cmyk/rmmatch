function computeFlexSlots(){
  const directIds=Array.from(document.querySelectorAll('#s-instructor-direct input:checked')).map(i=>i.value);
  // 비고정식: 과목 필터 없이 지정 강사의 모든 빈 슬롯
  let cands=directIds.length>0?instructors.filter(i=>directIds.includes(i.id)):[...instructors];

  const results=[];
  cands.forEach(ins=>{
    ins.days.forEach(day=>{
      ins.times.forEach(time=>{
        if(!isConflict(ins.id,day,time)){
          results.push({entries:[{instructor:ins,day,time}],multiInstructor:false,score:10,label:day+'요일 '+fmtTime(time)});
        }
      });
    });
  });
  // Sort by day order then time
  const dayOrder=['월','화','수','목','금','토','일'];
  results.sort((a,b)=>{
    const da=dayOrder.indexOf(a.entries[0].day),db=dayOrder.indexOf(b.entries[0].day);
    if(da!==db)return da-db;
    return a.entries[0].time.localeCompare(b.entries[0].time);
  });
  return results.slice(0,30);
}

