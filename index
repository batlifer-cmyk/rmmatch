// ── DAY-TIME ROWS (multi-select chips per day)
function renderDayTimeRows(){
  const selectedDays=getChecked('s-days');
  const wrap=document.getElementById('dayTimePicker');
  const container=document.getElementById('dayTimeRows');
  if(selectedDays.length===0){wrap.style.display='none';return;}
  wrap.style.display='block';

  // Preserve existing selections
  const existing={};
  container.querySelectorAll('.day-time-row').forEach(row=>{
    const d=row.dataset.day;
    existing[d]=Array.from(row.querySelectorAll('.time-chip.on')).map(c=>c.dataset.t);
  });

  container.innerHTML='';
  selectedDays.forEach(day=>{
    const row=document.createElement('div');
    row.className='day-time-row'; row.dataset.day=day;
    const lbl=document.createElement('span'); lbl.className='dlabel'; lbl.textContent=day+'요일 가능 시간';
    const chips=document.createElement('div'); chips.className='day-time-chips';

    const makeChip=(t,on=false)=>{
      const chip=document.createElement('div');
      chip.className='time-chip'+(on?' on':'');
      chip.dataset.t=t; chip.textContent=t;
      return chip;
    };

    TIMES.forEach(t=>{
      chips.appendChild(makeChip(t, !!(existing[day]&&existing[day].includes(t))));
    });

    // 직접입력 칩
    const directInput=document.createElement('input');
    directInput.type='text';
    directInput.className='time-direct-input';
    directInput.placeholder='직접입력';
    directInput.maxLength=5;
    directInput.title='예: 09:30';
    directInput.dataset.day=day;
    directInput.addEventListener('keydown',function(e){
      if(e.key==='Enter'){
        e.preventDefault();
        let val=this.value.trim();
        // 930 / 09:30 / 9:30 모두 허용
        const compact=val.match(/^(\d{1,2})(\d{2})$/);
        const colon=val.match(/^(\d{1,2}):(\d{2})$/);
        if(compact) val=compact[1].padStart(2,'0')+':'+compact[2];
        if(colon) val=colon[1].padStart(2,'0')+':'+colon[2];
        const [hh,mm]=val.split(':').map(Number);
        if(/^\d{2}:\d{2}$/.test(val)&&hh>=0&&hh<=23&&mm>=0&&mm<=59){
          if(!chips.querySelector(`.time-chip[data-t="${val}"]`)){
            chips.appendChild(makeChip(val,true));
          } else {
            chips.querySelector(`.time-chip[data-t="${val}"]`).classList.add('on');
          }
          this.value='';
        } else {
          this.style.borderColor='var(--danger)';
          setTimeout(()=>this.style.borderColor='',1000);
        }
      }
    });

    enableTimeChipSelection(chips);

    row.appendChild(lbl); row.appendChild(chips); row.appendChild(directInput); container.appendChild(row);
  });
}

// 시간칩 선택 전용 엔진: 클릭 단일 선택/해제 + 드래그 선택/해제를 분리한다.
function enableTimeChipSelection(chips){
  let dragActive=false;
  let dragMode=null; // 'on' | 'off'
  let lastChip=null;

  const applyMode=(chip)=>{
    if(!chip||!chip.classList.contains('time-chip'))return;
    chip.classList.toggle('on',dragMode==='on');
    chip.classList.add('selecting');
    lastChip=chip;
  };
  const clearSelecting=()=>{
    chips.querySelectorAll('.time-chip.selecting').forEach(c=>c.classList.remove('selecting'));
  };
  const stopDrag=()=>{
    if(!dragActive)return;
    dragActive=false;
    dragMode=null;
    lastChip=null;
    document.body.classList.remove('drag-selecting');
    setTimeout(clearSelecting,80);
  };

  chips.addEventListener('pointerdown',function(e){
    const chip=e.target.closest('.time-chip');
    if(!chip)return;
    e.preventDefault();
    dragActive=true;
    dragMode=chip.classList.contains('on')?'off':'on';
    document.body.classList.add('drag-selecting');
    try{chip.setPointerCapture(e.pointerId);}catch(_){/* Safari fallback */}
    applyMode(chip);
  });

  chips.addEventListener('pointerover',function(e){
    if(!dragActive)return;
    const chip=e.target.closest('.time-chip');
    if(chip&&chip!==lastChip)applyMode(chip);
  });

  chips.addEventListener('pointerup',stopDrag);
  chips.addEventListener('pointercancel',stopDrag);
  chips.addEventListener('mouseleave',function(){
    // 마우스를 칩 영역 밖으로 빼서 놓아도 선택 상태가 꼬이지 않게 한다.
    if(dragActive){
      document.addEventListener('pointerup',stopDrag,{once:true});
    }
  });
}

