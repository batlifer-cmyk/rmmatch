  if(el2)el2.textContent='전후 '+icsRangeWeeks+'주';
}

// ICS 날짜 파싱 — TZID 포함/UTC/로컬 모두 처리
function parseICSDate(s,tzid){
  s=s.trim().replace(/\r/g,'');
  const isUTC=s.endsWith('Z');
  const clean=s.replace('Z','');
  if(clean.length<8)return null;
  const y=+clean.slice(0,4),mo=+clean.slice(4,6)-1,d=+clean.slice(6,8);
  const hasTime=clean.length>8;
  const h=hasTime?+clean.slice(9,11):0;
  const mi=hasTime?+clean.slice(11,13):0;
  if(isUTC){
    // UTC → KST (+9)
    return new Date(Date.UTC(y,mo,d,h,mi)+9*3600*1000);
  }
  // TZID=Asia/Seoul 또는 로컬 → 한국시간으로 취급
  return new Date(y,mo,d,h,mi);
}

// ICS 텍스트 파싱 — 날짜 범위 필터 + RRULE 주간반복 처리
function parseICS(text){
  // unfold folded lines
  text=text.replace(/\r\n[ \t]/g,'').replace(/\r/g,'');
  const now=new Date(); now.setHours(0,0,0,0);
  const rangeMs=icsRangeWeeks*7*24*3600*1000;
  const rangeStart=new Date(now.getTime()-rangeMs);
  const rangeEnd=new Date(now.getTime()+rangeMs);
  const slots=[];
  const blocks=text.split('BEGIN:VEVENT');
  blocks.slice(1).forEach(block=>{
    const endIdx=block.indexOf('END:VEVENT');
    if(endIdx>-1)block=block.slice(0,endIdx);
    const getVal=(key)=>{
      const pat=new RegExp(key+'(?:;[^:]*)?:([^\\n]+)');
      const m=block.match(pat);
      return m?m[1].trim():'';
    };
    const getTZID=(key)=>{
      const pat=new RegExp(key+';TZID=([^:]+):([^\\n]+)');
      const m=block.match(pat);
      return m?{tzid:m[1].trim(),val:m[2].trim()}:null;
    };
    let dtStart=null;
    const tzStart=getTZID('DTSTART');
    if(tzStart) dtStart=parseICSDate(tzStart.val,tzStart.tzid);
    else{const v=getVal('DTSTART');if(v)dtStart=parseICSDate(v,'');}
    if(!dtStart)return;
    const rrule=getVal('RRULE');
    if(rrule&&rrule.includes('FREQ=WEEKLY')){
      const bydayM=rrule.match(/BYDAY=([^;]+)/);
      const byDays=bydayM
        ?bydayM[1].split(',').map(d=>d.trim().replace(/^[-+]?\d*/,''))
        :[['SU','MO','TU','WE','TH','FR','SA'][dtStart.getDay()]];
      const hour=dtStart.getHours();
      let untilDate=new Date(rangeEnd);
      const untilM=rrule.match(/UNTIL=([^;]+)/);
      if(untilM){const u=parseICSDate(untilM[1].trim(),'');if(u&&u<untilDate)untilDate=u;}
      byDays.forEach(dayCode=>{
        const dow=RRULE_DAY_MAP[dayCode];
        if(dow===undefined)return;
        let cur=new Date(rangeStart);
        while(cur.getDay()!==dow)cur.setDate(cur.getDate()+1);
        while(cur<=untilDate){
          if(cur>=dtStart)slots.push({dow,hour,dateStr:cur.toISOString().slice(0,10)});
          cur=new Date(cur);cur.setDate(cur.getDate()+7);
        }
      });
    } else {
      if(dtStart>=rangeStart&&dtStart<=rangeEnd)
        slots.push({dow:dtStart.getDay(),hour:dtStart.getHours(),dateStr:dtStart.toISOString().slice(0,10)});
    }
  });
  return slots;
}
function isConflictICS(insId,day,time){
  const cache=icsCache[insId];
  if(!cache||!cache.slots||!cache.slots.length)return false;
  const targetDow=DAY_KO.indexOf(day);
  const [h]=time.split(':').map(Number);
  return cache.slots.some(s=>s.dow===targetDow&&s.hour===h);
}

async function fetchICS(ins){
  if(!ins.calId)return[];
  const now=Date.now();
  if(icsCache[ins.id]&&now-icsCache[ins.id].fetched<10*60*1000)return icsCache[ins.id].slots;
  const proxies=[
    'https://api.allorigins.win/get?url=',
    'https://corsproxy.io/?'
  ];
  for(const proxy of proxies){
    try{
      const ctrl=new AbortController();
      const tid=setTimeout(()=>ctrl.abort(),8000);
      const res=await fetch(proxy+encodeURIComponent(ins.calId),{signal:ctrl.signal});
      clearTimeout(tid);
      let text='';
      if(proxy.includes('allorigins')){
        const json=await res.json();
        text=json.contents||'';
      } else {
        text=await res.text();
      }
      if(!text||!text.includes('VCALENDAR'))continue;
      const slots=parseICS(text);
      icsCache[ins.id]={fetched:now,slots};
      return slots;
    }catch(e){
      console.warn('proxy failed:',proxy,e.message);
    }
  }
  icsCache[ins.id]={fetched:now,slots:[]};
  return[];
}

